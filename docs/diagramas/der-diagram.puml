@startuml DER_Conekta
!define TABLE(name,pk,columns) class name << table >> {\n  **pk** : <<PK>>\n  columns\n}

entity USUARIO {
  * usuario_id : INT <<PK>>
  --
  * email : VARCHAR(255) <<UNIQUE>>
  * senha_hash : VARCHAR(255)
  * nome_completo : VARCHAR(255)
  tipo_conta : VARCHAR(50)
  data_criacao : TIMESTAMP
  data_atualizacao : TIMESTAMP
}

entity CATEGORIA {
  * categoria_id : INT <<PK>>
  --
  * nome : VARCHAR(100)
  descricao : TEXT
  codigo_cor : VARCHAR(7)
  icone : VARCHAR(50)
  data_criacao : TIMESTAMP
}

entity TRANSACAO {
  * transacao_id : INT <<PK>>
  --
  * usuario_id : INT <<FK>>
  * categoria_id : INT <<FK>>
  * descricao : VARCHAR(255)
  * valor : DECIMAL(10,2)
  * data_transacao : DATE
  observacao : TEXT
  eh_recorrente : BOOLEAN
  status : VARCHAR(20)
  data_criacao : TIMESTAMP
  data_atualizacao : TIMESTAMP
}

entity ORCAMENTO {
  * orcamento_id : INT <<PK>>
  --
  * usuario_id : INT <<FK>>
  * categoria_id : INT <<FK>>
  * valor_limite : DECIMAL(10,2)
  mes_periodo : INT
  ano_periodo : INT
  data_criacao : TIMESTAMP
  data_atualizacao : TIMESTAMP
}

entity ALERTA {
  * alerta_id : INT <<PK>>
  --
  * usuario_id : INT <<FK>>
  * tipo : VARCHAR(50)
  * mensagem : TEXT
  categoria_id : INT <<FK>>
  foi_lido : BOOLEAN
  data_criacao : TIMESTAMP
}

USUARIO ||--o{ TRANSACAO : "cria"
USUARIO ||--o{ ORCAMENTO : "define"
USUARIO ||--o{ ALERTA : "recebe"
CATEGORIA ||--o{ TRANSACAO : "classifica"
CATEGORIA ||--o{ ORCAMENTO : "limita"

note right of USUARIO
  Cada usuário possui múltiplas transações,
  orçamentos e alertas
end note

note right of TRANSACAO
  Registro de cada gasto realizado
  com categoria e data
end note

note right of ORCAMENTO
  Limite mensal de gastos
  por categoria
end note

note right of ALERTA
  Notificações de limite
  excedido ou gasto alto
end note

@enduml
